# InterrogationRoom 环境变量示例
# 复制为 .env 并填入实际值（.env 已被 .gitignore 忽略）

# ─── Provider 选择 ───
# 可选值: local_openai_compatible | anthropic_compatible | bytedance
# INTERROGATION_PROVIDER=anthropic_compatible

# ─── Anthropic / Claude ───
# ANTHROPIC_AUTH_TOKEN=your-token
# ANTHROPIC_BASE_URL=https://your-proxy/api

# ─── 本地模型 (Ollama) ───
# LOCAL_LLM_BASE_URL=http://127.0.0.1:11434/v1
# LOCAL_LLM_API_KEY=
# LOCAL_LLM_MODEL=deepseek-r1-14b-q4

# ─── 字节跳动 / 豆包 ───
# ByteDance_API_Key=your-key

# ─── 日志 ───
# INTERROGATION_LOG_LEVEL=INFO
# INTERROGATION_LOG_FILE=logs/game.log
